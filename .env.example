# Database
DATABASE_URL=postgresql+asyncpg://termin_user:your_password@localhost:5432/termin_notify
DATABASE_URL_SYNC=postgresql://termin_user:your_password@localhost:5432/termin_notify

# Redis (for Celery/background tasks)
REDIS_URL=redis://localhost:6379/0

# Application
SECRET_KEY=your-secret-key-change-this-in-production
ENVIRONMENT=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@termin-notify.de

# Stripe (Payment)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Scraping settings
SCRAPE_INTERVAL_MINUTES=5
MAX_CONCURRENT_SCRAPES=3
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Notification settings
MAX_NOTIFICATIONS_PER_USER_PER_DAY=50
NOTIFICATION_COOLDOWN_MINUTES=15
